<section class="sign-in">
  <div class="row">
    <div class="col-md-4"></div>
    <div class="col-md-4">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        
        <h4 class="fw-bold mb-4" style="color: #92aad0;">Log in to your account</h4>
        <p class="mb-4" style="color: #45526e;">To log in, please fill in these text fields with your e-mail address and password.</p>

        <div class="form-outline mb-4">
          <%= f.email_field :email, autofocus: true, class: "form-control", id: "email" %>
          <%= f.label :email, class: "form-label" %>
        </div>

        <div class="form-outline mb-4">
          <%= f.password_field :password, class: "form-control", id: "password" %>
          <%= f.label :password, class: "form-label" %>
        </div>

        <div class="form-outline mb-4">
          <% if devise_mapping.rememberable? %>
            <div class="field">
              <%= f.check_box :remember_me %>
              <%= f.label :remember_me %>
            </div>
          <% end %>
        </div>

        <div class="d-flex justify-content-end pt-1 mb-4">
          <%= f.submit "Sign in", class: "btn btn-primary btn-rounded", style: "background-color: #92aad0;" %>
        </div>
        <hr>
        <%= render "devise/shared/links" %>
      <% end %>
    </div>
    <div class="col-md-4"></div>
  </div>
</section>

