<section class="sign-up-form">
  <div class="row">
    <div class="col-md-4"></div>
    <div class="col-md-4">
      <div class="card">
        <div class="card-body">
          <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
            <h4 class="fw-bold mb-4" style="color: #92aad0;">Sign up for an Account</h4>
            <p class="mb-4" style="color: #45526e;">To sign up, please fill in these text fields.</p>

            <%= render "devise/shared/error_messages", resource: resource %>

            <div class="form-outline mb-4">
              <%= f.text_field :user_name, autofocus: true, class: "form-control" %>
              <%= f.label :user_name, class: "form-label" %>
            </div>

            <div class="form-outline mb-4">
              <%= f.text_field :first_name, class: "form-control" %>
              <%= f.label :first_name, class: "form-label" %>
            </div>

            <div class="form-outline mb-4">
              <%= f.text_field :last_name, class: "form-control" %>
              <%= f.label :last_name, class: "form-label" %>
            </div>

            <div class="form-outline mb-4">
              <%= f.email_field :email, class: "form-control" %>
              <%= f.label :email, class: "form-label" %>
            </div>
            
            <% if @minimum_password_length %>
              <em>(<%= @minimum_password_length %> characters minimum)</em>
            <% end %>
            <div class="form-outline mb-4">
              <%= f.password_field :password, class: "form-control" %>
              <%= f.label :password, class: "form-label" %>
            </div>

            <div class="form-outline mb-4">
              <%= f.password_field :password_confirmation, class: "form-control" %>
              <%= f.label :password_confirmation, class: "form-label" %>
            </div>
            <br>

            <div class="form-outline mb-4">
              <%= f.check_box :admin, class: "form-check-input" %>
              <%= f.label :admin, class: "form-label" %><br />
            </div>

            <div class="d-flex justify-content-end pt-1 mb-4">
              <%= f.submit "Sign up", class: "btn btn-primary btn-rounded", style: "background-color: #92aad0;" %>
            </div>

          <% end %>
          <hr>
          <%= render "devise/shared/links" %>
        </div>
      </div>
    </div>
    <div class="col-md-4"></div>
  </div>
</section>