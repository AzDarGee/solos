<div class="container fixed-top container-messages">
    <% if flash[:notice] %>
        <div class="alert alert-warning alert-info fade show system-messages">
            <%= notice %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    <% end %>
    <% if flash[:alert] %>
        <div class="alert alert-warning alert-warning fade show system-messages">
            <%= alert %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    <% end %>
</div>