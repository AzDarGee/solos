<section class="all-projects">
  <% @all_projects.each do |project| %>
    <section class="mx-auto my-5 project-card">

      <div class="card">
        <div class="card-body d-flex flex-row">
          <% if project.user.avatar.attached? %>
            <%= image_tag project.user.avatar.url, class: "rounded-circle me-3", width: 50, height: 50 %>
          <% end %>
          <div>
            <h5 class="card-title font-weight-bold mb-2">
              <%= link_to project.title, project %>
            </h5>
            <p class="card-text"><i class="far fa-clock pe-2"></i><%= project.end_date.strftime("%B %d, %Y") %></p>
            <p class="user-name fa fa-user">
                <%= project.user.user_name %>
            </p>
          </div>
        </div>

        <div class="bg-image hover-overlay ripple rounded-0" data-mdb-ripple-color="light">
          <a href="<%= project_path(project) %>">
            <% if project.images.attached? %>
              <%= image_tag project.thumbnail(0), class: "img-fluid" %>
            <% end %>
          
            <div class="mask" style="background-color: rgba(0, 0, 0, 0.45);">
              <div class="mask-text">
                <%= project.title %> 
                <br />
                <%= project.end_date.strftime("%B %d, %Y") %>
              </div>
            </div>
          </a>
        </div>

      </div>
    </section>
  <% end %>
</section>


